<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="javafxapplicationproduit.ProduitController"
      spacing="15" style="-fx-background-color: #f0f2f8;">
    
    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>
    
    
    <Label text="Gestion des Produits" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e3a6f;">
        <VBox.margin>
            <Insets bottom="5"/>
        </VBox.margin>
        <effect>
            <DropShadow color="rgba(0,0,0,0.05)" radius="4" offsetX="0" offsetY="2"/>
        </effect>
    </Label>
    
    
    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 10 15; -fx-background-radius: 12; -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
        <Label text="Rechercher :" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
        <TextField fx:id="searchField" promptText="Par libellé ou catégorie..." HBox.hgrow="ALWAYS" 
                   style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
        <Button text="Effacer" onAction="#handleClearSearch" 
                style="-fx-background-color: #cbd5e1; -fx-text-fill: #2d3748; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 18; -fx-cursor: hand;"/>
    </HBox>
    
    <Separator style="-fx-background-color: #e2e8f0; -fx-pref-height: 1;"/>
    
    
    <GridPane hgap="15" vgap="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 3);">
        
        <Label text="Code :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
        <TextField fx:id="codeField" promptText="Code produit" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220" 
                   style="-fx-background-color: #f9fafb; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
        
        <Label text="Libellé :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
        <TextField fx:id="libelleField" promptText="Libellé produit" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                   style="-fx-background-color: #f9fafb; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
        
        <Label text="Type :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
        <ComboBox fx:id="typeComboBox" promptText="Sélectionner un type" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="220" editable="true"
                  style="-fx-background-color: #f9fafb; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 4 8;"/>
        
        <Label text="Quantite en stock :" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
        <TextField fx:id="quantiteField" promptText="Quantite" GridPane.rowIndex="3" GridPane.columnIndex="1" 
                   style="-fx-background-color: #f9fafb; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
        
        <Label text="Disponibilite :" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
        <CheckBox fx:id="disponibiliteCheckBox" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-text-fill: #2d3748;"/>
        
       
        <TextField fx:id="idField" visible="false" managed="false" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>
    
    
    <HBox spacing="12" alignment="CENTER">
        <Button text="Ajouter" onAction="#handleAjouter" 
                style="-fx-background-color: #2c7a4d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 25; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(44,122,77,0.2), 4, 0, 0, 2);">
            <HBox.margin>
                <Insets right="5"/>
            </HBox.margin>
        </Button>
        <Button text="Modifier" onAction="#handleModifier" 
                style="-fx-background-color: #00BCD4; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 25; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(44,110,158,0.2), 4, 0, 0, 2);">
            <HBox.margin>
                <Insets right="5"/>
            </HBox.margin>
        </Button>
        <Button text="Supprimer" onAction="#handleSupprimer" 
                style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 25; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(192,57,43,0.2), 4, 0, 0, 2);">
            <HBox.margin>
                <Insets right="5"/>
            </HBox.margin>
        </Button>
        <Button text="Actualiser" onAction="#handleActualiser" 
                style="-fx-background-color: #d97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 25; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(217,119,6,0.2), 4, 0, 0, 2);"/>
    </HBox>
    
    <Separator style="-fx-background-color: #4CAF50; -fx-pref-height: 1;"/>
    
    
    <VBox VBox.vgrow="ALWAYS" spacing="10">
        <Label text="Liste des Produits" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e3a6f;">
            <VBox.margin>
                <Insets bottom="2"/>
            </VBox.margin>
        </Label>
        <TableView fx:id="produitTableView" VBox.vgrow="ALWAYS" 
                   style="-fx-border-color: #2196F3; -fx-border-radius: 12; -fx-background-radius: 12; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
            <columns>
                <TableColumn text="ID" prefWidth="50" fx:id="colId"/>
                <TableColumn text="Code" prefWidth="100" fx:id="colCode"/>
                <TableColumn text="Libellé" prefWidth="150" fx:id="colLibelle"/>
                <TableColumn text="Type" prefWidth="100" fx:id="colType"/>
                <TableColumn text="Quantité" prefWidth="80" fx:id="colQuantite"/>
                <TableColumn text="Disponibilité" prefWidth="100" fx:id="colDisponibilite"/>
            </columns>
        </TableView>
    </VBox>
    
</VBox>
